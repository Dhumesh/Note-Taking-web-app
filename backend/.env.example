# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas: use your cluster HOST (e.g. cluster0.xxxxx.mongodb.net from Atlas Connect).
# "note-app" is the database name (auto-created); it is NOT a cluster name.
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/note-app?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/note-app

# JWT - use a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production
