# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas: replace <db_password> with your Atlas user password.
# MONGODB_URI=mongodb+srv://admin:<db_password>@cluster0.ybqxp9g.mongodb.net/note-app?retryWrites=true&w=majority
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/note-app

# JWT - use a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production
